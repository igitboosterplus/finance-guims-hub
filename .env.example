VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_AUTH_EMAIL_DOMAIN=auth.guims.local

# Public frontend config
VITE_AI_REPORT_PROVIDER=gemini
VITE_AI_REPORT_AVAILABLE_PROVIDERS=openai,gemini
VITE_ENABLE_PUBLIC_REGISTRATION=false
VITE_SECURE_WRITE_FUNCTION_NAME=secure-write
VITE_AUTH_ROLE_CLAIM_FUNCTION_NAME=provision-auth-claim
VITE_AUTH_ADMIN_FUNCTION_NAME=auth-admin-user
VITE_ALLOW_INSECURE_DIRECT_SYNC=false

# Server-side secrets for Supabase Edge Functions
# Set these with: supabase secrets set OPENAI_API_KEY=... GEMINI_API_KEY=...
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_REPORT_PROVIDER=gemini
AI_ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com
AI_ALLOWED_APP_ROLES=superadmin,admin
AI_ALLOW_INSECURE_ROLE_HEADER=false
AI_MAX_BODY_BYTES=200000

# Secure write function
SECURE_WRITE_ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com
SECURE_WRITE_ALLOWED_APP_ROLES=superadmin,admin
SECURE_WRITE_MAX_BODY_BYTES=250000

# Auth role claim provisioning function
AUTH_CLAIM_ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com
AUTH_CLAIM_ALLOWED_APP_ROLES=superadmin,admin

# Auth admin user function
AUTH_EMAIL_DOMAIN=auth.guims.local
AUTH_ADMIN_ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com
AUTH_ADMIN_ALLOWED_APP_ROLES=superadmin,admin
