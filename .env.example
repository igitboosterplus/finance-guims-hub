VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Public frontend config
VITE_AI_REPORT_PROVIDER=gemini
VITE_AI_REPORT_AVAILABLE_PROVIDERS=openai,gemini

# Server-side secrets for Supabase Edge Functions
# Set these with: supabase secrets set OPENAI_API_KEY=... GEMINI_API_KEY=...
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AI_REPORT_PROVIDER=gemini
AI_ALLOWED_ORIGINS=http://localhost:8080,https://your-domain.com
AI_ALLOWED_APP_ROLES=superadmin,admin
